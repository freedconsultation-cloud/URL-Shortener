    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "nanoid": "^3.3.7",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4"
  }
}
